# CoinMarketCap Pro API — free tier is sufficient
# (the free tier does NOT include /v2/cryptocurrency/ohlcv/historical;
#  historical OHLCV comes from Binance public klines instead — no key needed)
#
# Sign up: https://coinmarketcap.com/api/pricing/ (Basic tier, free)
# Endpoint base: https://pro-api.coinmarketcap.com
CMC_API_KEY=

# Optional — node env mode
NODE_ENV=development
